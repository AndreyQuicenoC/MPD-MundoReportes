# ================================================================
# MUNDO REPORTE - CONFIGURACIÓN DE ENTORNO
# ================================================================
# Copia este archivo a .env y completa con tus datos reales.
# NO SUBAS el archivo .env al repositorio (está en .gitignore).
# ================================================================

# ================================================================
# DJANGO SETTINGS
# ================================================================

# SECURITY WARNING: Genera una clave secreta fuerte en producción
# Puedes generar una con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-this-in-production-REEMPLAZAR-CON-CLAVE-SEGURA

# DEBUG: True solo en desarrollo, False en producción
DEBUG=True

# Hosts permitidos (separados por coma, sin espacios)
# En producción agrega tu dominio: ejemplo.com,www.ejemplo.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ================================================================
# SUPABASE DATABASE CONFIGURATION
# ================================================================
# Obtén estos valores desde tu proyecto de Supabase:
# 1. Ve a: https://app.supabase.com/project/TU_PROYECTO/settings/database
# 2. En la sección "Connection string" selecciona "URI"
# 3. Copia la cadena de conexión y reemplaza [YOUR-PASSWORD] con tu contraseña real

# IMPORTANTE: La URL debe seguir este formato exacto:
# postgresql://postgres.REFERENCIA:[PASSWORD]@HOST:5432/postgres
# 
# Ejemplo real (NO USES ESTE, USA EL TUYO):
# DATABASE_URL=postgresql://postgres.abcdefghijklmnop:tu_password_segura@aws-0-us-east-1.pooler.supabase.com:5432/postgres
#
# Donde:
# - postgres.abcdefghijklmnop = Tu referencia del proyecto (aparece en Settings > Database)
# - tu_password_segura = La contraseña que creaste al crear el proyecto
# - aws-0-us-east-1.pooler.supabase.com = El host de tu región (aparece en Settings > Database)
# - 5432 = Puerto de PostgreSQL (siempre es 5432)
# - postgres = Nombre de la base de datos (siempre es postgres en Supabase)

DATABASE_URL=postgresql://postgres.REFERENCIA:PASSWORD@HOST:5432/postgres

# ================================================================
# SUPABASE API CONFIGURATION (Opcional - para funcionalidades adicionales)
# ================================================================
# Si deseas usar Storage, Auth u otras funcionalidades de Supabase:
# Ve a: https://app.supabase.com/project/TU_PROYECTO/settings/api

# URL del proyecto (ejemplo: https://abcdefghijklmnop.supabase.co)
SUPABASE_URL=https://TU_REFERENCIA.supabase.co

# Clave pública anónima (anon/public key)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ================================================================
# CORS SETTINGS
# ================================================================
# URLs permitidas para acceso desde el frontend (separadas por coma)
# En desarrollo:
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# En producción agrega tu dominio del frontend:
# CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app,https://www.tu-dominio.com

# ================================================================
# JWT SETTINGS
# ================================================================
# Tiempo de vida del token de acceso en minutos (60 = 1 hora)
JWT_ACCESS_TOKEN_LIFETIME=60

# Tiempo de vida del token de refresco en minutos (1440 = 24 horas)
JWT_REFRESH_TOKEN_LIFETIME=1440

# ================================================================
# GUÍA RÁPIDA: CÓMO OBTENER TUS CREDENCIALES DE SUPABASE
# ================================================================
# 
# 1. CREAR PROYECTO EN SUPABASE:
#    - Ve a https://app.supabase.com
#    - Crea una cuenta o inicia sesión
#    - Clic en "New Project"
#    - Nombre del proyecto: mundo-reporte (o el que prefieras)
#    - Password: Crea una contraseña SEGURA (guárdala, la necesitarás)
#    - Región: Elige la más cercana (ej: South America (São Paulo))
#    - Clic en "Create new project" y espera ~2 minutos
#
# 2. OBTENER DATABASE_URL:
#    - En el menú lateral: Settings > Database
#    - Busca la sección "Connection string"
#    - Selecciona el modo "URI"
#    - Copia la cadena que aparece
#    - Reemplaza [YOUR-PASSWORD] con la contraseña del paso 1
#    - Pega la cadena completa en DATABASE_URL arriba
#
# 3. EJECUTAR EL SCHEMA SQL:
#    - En el menú lateral: SQL Editor
#    - Clic en "New query"
#    - Abre el archivo supabase_schema.sql del proyecto
#    - Copia TODO el contenido y pégalo en el editor
#    - Clic en "Run" (o Ctrl+Enter)
#    - Verifica que se ejecutó sin errores
#
# 4. OBTENER API KEYS (Opcional):
#    - En el menú lateral: Settings > API
#    - Copia "Project URL" y pégalo en SUPABASE_URL
#    - Copia "anon public" key y pégalo en SUPABASE_ANON_KEY
#
# 5. VERIFICAR CONFIGURACIÓN:
#    - Guarda este archivo como .env
#    - Ejecuta: python manage.py migrate
#    - Si todo está bien, verás: "No migrations to apply"
#    - Crea un superusuario: python manage.py createsuperuser
#
# ================================================================
# NOTAS IMPORTANTES
# ================================================================
# - La base de datos en Supabase ya tiene el esquema creado por el SQL
# - NO ejecutes makemigrations/migrate al inicio (el schema ya existe)
# - Guarda tu contraseña de Supabase en un lugar seguro
# - En producción usa SECRET_KEY diferente y DEBUG=False
# - El plan gratuito de Supabase incluye:
#   * 500 MB de espacio en base de datos
#   * 1 GB de transferencia
#   * 2 GB de almacenamiento (Storage)
#   * Backups automáticos por 7 días
# ================================================================

