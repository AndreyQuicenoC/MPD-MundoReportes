# ================================================================
# EJEMPLO DE CONFIGURACIÓN .ENV PARA SUPABASE
# ================================================================
# Este archivo muestra cómo se ve un .env correctamente configurado.
# Reemplaza los valores de ejemplo con los tuyos reales.
# ================================================================

# Django Secret Key (genera uno nuevo con el comando indicado abajo)
SECRET_KEY=django-insecure-7k#p9m$x2@w8v!3n5h*j6q1r4t7u9y0e-s8d5f6g7h8j9k0l

# Debug (True en desarrollo, False en producción)
DEBUG=True

# Hosts permitidos
ALLOWED_HOSTS=localhost,127.0.0.1

# ================================================================
# SUPABASE DATABASE - EJEMPLO REAL
# ================================================================
# Tu cadena de conexión se verá similar a esta:
# Obtén la tuya desde: Settings > Database > Connection string (URI mode)

DATABASE_URL=postgresql://postgres.abcdefghijklmnop:MiPassword123Segura@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Donde:
# - postgres.abcdefghijklmnop = Tu referencia del proyecto Supabase
# - MiPassword123Segura = La contraseña que creaste al crear el proyecto
# - aws-0-us-east-1.pooler.supabase.com = Host de tu región
# - 5432 = Puerto PostgreSQL (siempre es este)
# - postgres = Nombre de la base de datos (siempre es postgres en Supabase)

# ================================================================
# CORS (Frontend URLs permitidas)
# ================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# En producción agrega tu dominio:
# CORS_ALLOWED_ORIGINS=https://mundo-reporte.vercel.app,https://www.tu-dominio.com

# ================================================================
# JWT Settings
# ================================================================
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ================================================================
# COMANDOS ÚTILES
# ================================================================

# Para generar un SECRET_KEY nuevo:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# Para verificar la conexión a Supabase:
# python manage.py migrate

# Para crear un superusuario:
# python manage.py createsuperuser

# Para iniciar el servidor:
# python manage.py runserver
